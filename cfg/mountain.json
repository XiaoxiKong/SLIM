{
    "log_dir": "logs",
    "output_dir": "output/checkpoints",
    "output_data_dir": "output/data",
    "data_dir": "path/to/dataset",
    "data_root_path": "path/to/images",
    "data_test_path": "path/to/val_images",
    "data_json_file": "path/to/annotations.json",
    "ckpt_name": "watermark_lora",
    "gradient_accumulation_steps": 1,
    "pretrained_model_name_or_path": "runwayml/stable-diffusion-v1-5",
    "rank": 50,
    "enable_xformers_memory_efficient_attention": true,
    "learning_rate": 1e-4,
    "learning_rate_lora": 1e-4,
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,
    "adam_weight_decay": 1e-2,
    "adam_epsilon": 1e-08,
    "resolution": 512,
    "n_epochs": 30,
    "checkpointing_steps": 1000,
    "validation_epochs": 1,
    "train_batch_size": 1,
    "dataloader_num_workers": 4,
    "lr_scheduler_name": "constant",
    "resume_from_checkpoint": false,
    "noise_offset": 0.1,
    "max_grad_norm": 1.0,
    "lambda_3": 0.05,
    "lambda_2": 4,
    "lambda_1": 1,
    "secret_len": 48,
    "config": "VQ4_mir.yaml",
    "max_image_weight_ratio": 2.0
}
